from sc2 import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get all our units
        colossus = self.units(UnitTypeId.COLOSSUS)
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Get enemy units
        enemy_colossus = self.enemy_units(UnitTypeId.COLOSSUS)
        enemy_stalkers = self.enemy_units(UnitTypeId.STALKER)
        enemy_zealots = self.enemy_units(UnitTypeId.ZEALOT)

        # Colossus micro: Stay at max range and attack enemy units
        if colossus:
            colossus_unit = colossus.first
            if enemy_colossus:
                colossus_unit.attack(enemy_colossus.closest_to(colossus_unit))
            elif enemy_stalkers:
                colossus_unit.attack(enemy_stalkers.closest_to(colossus_unit))
            elif enemy_zealots:
                colossus_unit.attack(enemy_zealots.closest_to(colossus_unit))

        # Stalker micro: Kite enemy Zealots
        if stalkers:
            for stalker in stalkers:
                if enemy_zealots:
                    closest_enemy_zealot = enemy_zealots.closest_to(stalker)
                    if stalker.distance_to(closest_enemy_zealot) < 6:
                        stalker.move(stalker.position.towards(closest_enemy_zealot, -4))
                    else:
                        stalker.attack(closest_enemy_zealot)
                elif enemy_stalkers:
                    stalker.attack(enemy_stalkers.closest_to(stalker))

        # Zealot micro: Engage enemy Stalkers
        if zealots:
            for zealot in zealots:
                if enemy_stalkers:
                    zealot.attack(enemy_stalkers.closest_to(zealot))
                elif enemy_zealots:
                    zealot.attack(enemy_zealots.closest_to(zealot))

        # If no enemies are found, move towards the enemy base
        if not enemy_colossus and not enemy_stalkers and not enemy_zealots:
            if colossus:
                colossus.first.attack(Point2((23, 16)))
            if stalkers:
                for stalker in stalkers:
                    stalker.attack(Point2((23, 16)))
            if zealots:
                for zealot in zealots:
                    zealot.attack(Point2((23, 16)))
```

### Explanation:
- **Colossus**: The Colossus will stay at its maximum range and attack the closest enemy unit. It prioritizes enemy Colossus, then Stalkers, and finally Zealots.
- **Stalkers**: Stalkers will kite enemy Zealots by moving away if the Zealots get too close, otherwise, they will attack. If no Zealots are present, they will attack enemy Stalkers.
- **Zealots**: Zealots will engage enemy Stalkers first. If no Stalkers are present, they will attack enemy Zealots.

This strategy aims to maximize the effectiveness of each unit type by leveraging their strengths and minimizing their weaknesses.
