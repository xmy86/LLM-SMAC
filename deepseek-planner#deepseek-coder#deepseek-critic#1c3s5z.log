                if enemy_stalkers:
                    zealot.attack(enemy_stalkers.closest_to(zealot))
                elif enemy_colossus:
                    zealot.attack(enemy_colossus)
                elif enemy_zealots:
                    zealot.attack(enemy_zealots.closest_to(zealot))

        # Ensure all units are moving towards the enemy target if no enemies are in range
        if not self.enemy_units:
            if colossus:
                colossus.attack(enemy_target)
            if stalkers:
                for stalker in stalkers:
                    stalker.attack(enemy_target)
            if zealots:
                for zealot in zealots:
                    zealot.attack(enemy_target)
