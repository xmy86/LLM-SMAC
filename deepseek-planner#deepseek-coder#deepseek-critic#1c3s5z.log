            elif enemy_stalkers:
                colossus.attack(enemy_stalkers.closest_to(colossus))
            elif enemy_colossus:
                colossus.attack(enemy_colossus)

        if stalkers:
            # Stalkers should kite enemy Zealots and focus on enemy Stalkers
            for stalker in stalkers:
