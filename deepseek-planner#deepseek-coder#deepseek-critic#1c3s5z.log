class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get our units
        my_colossus = self.units(UnitTypeId.COLOSSUS).first
        my_stalkers = self.units(UnitTypeId.STALKER)
        my_zealots = self.units(UnitTypeId.ZEALOT)

        # Get enemy units
        enemy_colossus = self.enemy_units.of_type([UnitTypeId.COLOSSUS]).first
        enemy_stalkers = self.enemy_units.of_type([UnitTypeId.STALKER])
        enemy_zealots = self.enemy_units.of_type([UnitTypeId.ZEALOT])

        # Micro for Colossus
        if my_colossus and enemy_colossus:
            my_colossus.attack(enemy_colossus)

        # Micro for Stalkers
        if my_stalkers and enemy_stalkers:
            for stalker in my_stalkers:
                closest_enemy_stalker = enemy_stalkers.closest_to(stalker)
                if closest_enemy_stalker:
                    stalker.attack(closest_enemy_stalker)

        # Micro for Zealots
        if my_zealots and enemy_zealots:
            for zealot in my_zealots:
                closest_enemy_zealot = enemy_zealots.closest_to(zealot)
                if closest_enemy_zealot:
                    zealot.attack(closest_enemy_zealot)

        # If there are no enemy units, move towards the enemy base
        if not self.enemy_units:
            for unit in self.units:
                unit.attack(Point2((23, 16)))

# Run the bot
