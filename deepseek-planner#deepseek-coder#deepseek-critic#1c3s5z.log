from sc2 import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get all our units
        colossus = self.units(UnitTypeId.COLOSSUS).first
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Get enemy units
        enemy_colossus = self.enemy_units(UnitTypeId.COLOSSUS).first
        enemy_stalkers = self.enemy_units(UnitTypeId.STALKER)
        enemy_zealots = self.enemy_units(UnitTypeId.ZEALOT)

        # Define the initial position of our Stalkers
        stalker_position = Point2((9, 16))

        # Colossus micro: Focus on enemy Zealots first, then Stalkers, then Colossus
        if colossus:
            if enemy_zealots:
                colossus.attack(enemy_zealots.closest_to(colossus))
            elif enemy_stalkers:
                colossus.attack(enemy_stalkers.closest_to(colossus))
            elif enemy_colossus:
                colossus.attack(enemy_colossus)

        # Stalker micro: Focus on enemy Stalkers first, then Colossus, then Zealots
        for stalker in stalkers:
            if enemy_stalkers:
                stalker.attack(enemy_stalkers.closest_to(stalker))
            elif enemy_colossus:
                stalker.attack(enemy_colossus)
            elif enemy_zealots:
                stalker.attack(enemy_zealots.closest_to(stalker))

        # Zealot micro: Focus on enemy Zealots first, then Stalkers, then Colossus
        for zealot in zealots:
            if enemy_zealots:
                zealot.attack(enemy_zealots.closest_to(zealot))
            elif enemy_stalkers:
                zealot.attack(enemy_stalkers.closest_to(zealot))
            elif enemy_colossus:
                zealot.attack(enemy_colossus)

        # Retreat low-health units to the initial Stalker position
        for unit in self.units:
            if unit.health_percentage < 0.5:
                unit.move(stalker_position)

        # If no enemies are in range, move towards the enemy position
        if not self.enemy_units.closer_than(10, stalker_position):
            for unit in self.units:
                unit.move(Point2((23, 16)))
```

