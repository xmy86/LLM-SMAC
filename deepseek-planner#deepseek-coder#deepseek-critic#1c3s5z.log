Here is the Python code implementing the strategy:

```python
from sc2 import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get all our units
        colossus = self.units(UnitTypeId.COLOSSUS)
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Get enemy units
        enemy_colossus = self.enemy_units(UnitTypeId.COLOSSUS)
        enemy_stalkers = self.enemy_units(UnitTypeId.STALKER)
        enemy_zealots = self.enemy_units(UnitTypeId.ZEALOT)

        # Define the target point for enemy units
        enemy_target = Point2((9, 16))

        # Micro-management for Colossus
        if colossus:
            colossus_unit = colossus.first
            # Move Colossus to a safe position while attacking
            if enemy_zealots:
                colossus_unit.attack(enemy_zealots.closest_to(colossus_unit))
            elif enemy_stalkers:
                colossus_unit.attack(enemy_stalkers.closest_to(colossus_unit))
            else:
                colossus_unit.attack(enemy_colossus.closest_to(colossus_unit))

        # Micro-management for Stalkers (kiting)
        if stalkers:
            for stalker in stalkers:
                # If enemy Zealots are close, retreat while attacking
                if enemy_zealots:
                    closest_zealot = enemy_zealots.closest_to(stalker)
                    if stalker.distance_to(closest_zealot) < 6:
                        stalker.move(stalker.position.towards(self.start_location, 4))
                    else:
                        stalker.attack(closest_zealot)
                # Otherwise, attack the closest enemy Stalker or Colossus
                elif enemy_stalkers:
                    stalker.attack(enemy_stalkers.closest_to(stalker))
                elif enemy_colossus:
                    stalker.attack(enemy_colossus.closest_to(stalker))

        # Micro-management for Zealots
        if zealots:
            for zealot in zealots:
                # Engage enemy Zealots in melee combat
                if enemy_zealots:
                    zealot.attack(enemy_zealots.closest_to(zealot))
                # Otherwise, attack enemy Stalkers or Colossus
                elif enemy_stalkers:
                    zealot.attack(enemy_stalkers.closest_to(zealot))
                elif enemy_colossus:
                    zealot.attack(enemy_colossus.closest_to(zealot))

        # If no enemy units are visible, move towards the enemy target
        if not self.enemy_units:
            if colossus:
                colossus.first.attack(enemy_target)
            if stalkers:
                for stalker in stalkers:
                    stalker.attack(enemy_target)
            if zealots:
                for zealot in zealots:
                    zealot.attack(enemy_target)
```

This code implements a basic micro-management strategy where:
- The Colossus focuses on dealing AoE damage to enemy Zealots or Stalkers.
- Stalkers kite enemy Zealots by retreating while attacking if the Zealots get too close.
- Zealots engage in melee combat with enemy Zealots or attack other units if no Zealots are present.

Make sure to adjust the strategy based on the actual game state and unit positions.
