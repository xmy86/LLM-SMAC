from sc2 import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get all our units
        colossus = self.units(UnitTypeId.COLOSSUS)
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Enemy units are at (23, 16)
        enemy_position = Point2((23, 16))

        # If we have a Colossus, focus on kiting enemy Zealots
        if colossus:
            colossus_unit = colossus.first
            enemy_zealots = self.enemy_units(UnitTypeId.ZEALOT)
            if enemy_zealots:
                # Move away from enemy Zealots while attacking
                closest_enemy_zealot = enemy_zealots.closest_to(colossus_unit)
                if colossus_unit.distance_to(closest_enemy_zealot) < 7:
                    colossus_unit.move(colossus_unit.position.towards(closest_enemy_zealot, -7))
                colossus_unit.attack(closest_enemy_zealot)

        # Stalkers should focus on enemy Colossus
        if stalkers:
            enemy_colossus = self.enemy_units(UnitTypeId.COLOSSUS)
            if enemy_colossus:
                for stalker in stalkers:
                    stalker.attack(enemy_colossus.first)
            else:
                # If no enemy Colossus, attack enemy Stalkers
                enemy_stalkers = self.enemy_units(UnitTypeId.STALKER)
                if enemy_stalkers:
                    for stalker in stalkers:
                        stalker.attack(enemy_stalkers.closest_to(stalker))

        # Zealots should focus on enemy Stalkers
        if zealots:
            enemy_stalkers = self.enemy_units(UnitTypeId.STALKER)
            if enemy_stalkers:
                for zealot in zealots:
                    zealot.attack(enemy_stalkers.closest_to(zealot))
            else:
                # If no enemy Stalkers, attack enemy Zealots
                enemy_zealots = self.enemy_units(UnitTypeId.ZEALOT)
                if enemy_zealots:
                    for zealot in zealots:
                        zealot.attack(enemy_zealots.closest_to(zealot))

        # If no specific targets, move towards the enemy position
        if not colossus and not stalkers and not zealots:
            for unit in self.units:
                unit.attack(enemy_position)
