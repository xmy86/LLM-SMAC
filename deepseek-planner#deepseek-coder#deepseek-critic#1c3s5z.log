from sc2.bot_ai import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Define your units
        colossus = self.units(UnitTypeId.COLOSSUS).first
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Define enemy units
        enemy_colossus = self.enemy_units.of_type(UnitTypeId.COLOSSUS).first
        enemy_stalkers = self.enemy_units.of_type(UnitTypeId.STALKER)
        enemy_zealots = self.enemy_units.of_type(UnitTypeId.ZEALOT)

        # Define the target point for your units
        target_point = Point2((23, 16))

        # Micro-management for Colossus
        if colossus:
            # Move towards the enemy
            colossus.attack(target_point)

            # Attack the closest enemy unit
            if enemy_colossus:
                colossus.attack(enemy_colossus)
            elif enemy_stalkers:
                colossus.attack(enemy_stalkers.closest_to(colossus))
            elif enemy_zealots:
                colossus.attack(enemy_zealots.closest_to(colossus))

        # Micro-management for Stalkers
        for stalker in stalkers:
            # Move towards the enemy
            stalker.attack(target_point)

            # Attack the closest enemy unit
            if enemy_stalkers:
                stalker.attack(enemy_stalkers.closest_to(stalker))
            elif enemy_zealots:
                stalker.attack(enemy_zealots.closest_to(stalker))
            elif enemy_colossus:
                stalker.attack(enemy_colossus)

        # Micro-management for Zealots
        for zealot in zealots:
            # Move towards the enemy
            zealot.attack(target_point)

            # Attack the closest enemy unit
            if enemy_zealots:
                zealot.attack(enemy_zealots.closest_to(zealot))
            elif enemy_stalkers:
                zealot.attack(enemy_stalkers.closest_to(zealot))
            elif enemy_colossus:
                zealot.attack(enemy_colossus)
```

