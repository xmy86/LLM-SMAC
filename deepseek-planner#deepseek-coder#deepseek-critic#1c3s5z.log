from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MicroBot(BotAI):
    async def on_step(self, iteration: int):
        # Get all our units
        colossus = self.units(UnitTypeId.COLOSSUS).first
        stalkers = self.units(UnitTypeId.STALKER)
        zealots = self.units(UnitTypeId.ZEALOT)

        # Enemy units are moving towards (9, 16)
        enemy_target = Point2((9, 16))

        # Micro-management strategy:
        # 1. Colossus should stay behind Stalkers and Zealots, attacking from a safe distance.
        # 2. Stalkers should kite enemy units, moving back while attacking.
        # 3. Zealots should engage enemy Zealots and Stalkers, focusing on the closest enemy.

        # Colossus micro
        if colossus:
            # Colossus should stay behind the Stalkers and Zealots
            if stalkers:
                colossus.move(stalkers.center)
            elif zealots:
                colossus.move(zealots.center)
            # Attack the closest enemy unit
            enemy_units = self.enemy_units.closer_than(7, colossus.position)
            if enemy_units:
                colossus.attack(enemy_units.closest_to(colossus.position))

        # Stalker micro
        for stalker in stalkers:
            # Kite enemy units: move back while attacking
            enemy_units = self.enemy_units.closer_than(6, stalker.position)
            if enemy_units:
                closest_enemy = enemy_units.closest_to(stalker.position)
                stalker.attack(closest_enemy)
                # Move away from the closest enemy
                stalker.move(stalker.position.towards(closest_enemy, -4))
            else:
                # Move towards the enemy target if no enemies are in range
                stalker.move(enemy_target)

        # Zealot micro
        for zealot in zealots:
            # Engage the closest enemy unit
            enemy_units = self.enemy_units.closer_than(0.1, zealot.position)
            if enemy_units:
                closest_enemy = enemy_units.closest_to(zealot.position)
                zealot.attack(closest_enemy)
            else:
                # Move towards the enemy target if no enemies are in range
                zealot.move(enemy_target)
