from sc2.bot_ai import BotAI
from sc2.ids.unit_typeid import UnitTypeId
from sc2.position import Point2

class MyBot(BotAI):
    async def on_step(self, iteration: int):
        # Define your units
        colossus = self.units.of_type(UnitTypeId.COLOSSUS).first
        stalkers = self.units.of_type(UnitTypeId.STALKER)
        zealots = self.units.of_type(UnitTypeId.ZEALOT)

        # Define enemy units
        enemy_colossus = self.enemy_units.of_type(UnitTypeId.COLOSSUS).first
        enemy_stalkers = self.enemy_units.of_type(UnitTypeId.STALKER)
        enemy_zealots = self.enemy_units.of_type(UnitTypeId.ZEALOT)

        # Define the target point for your units
        target_point = Point2((23, 16))

        # Micro-management strategy
        if colossus:
            # Colossus should attack the enemy Colossus if it exists, otherwise attack the closest enemy unit
            if enemy_colossus:
                colossus.attack(enemy_colossus)
            else:
                closest_enemy = self.enemy_units.closest_to(colossus)
                if closest_enemy:
                    colossus.attack(closest_enemy)

        if stalkers:
            # Stalkers should kite the enemy units, attacking and then retreating slightly
            for stalker in stalkers:
                if enemy_stalkers or enemy_zealots:
                    closest_enemy = self.enemy_units.closest_to(stalker)
                    if closest_enemy:
                        if stalker.distance_to(closest_enemy) > 6:
                            stalker.attack(closest_enemy)
                        else:
                            stalker.move(stalker.position.towards(closest_enemy, -2))

        if zealots:
            # Zealots should charge towards the enemy Zealots and engage in melee combat
            for zealot in zealots:
                if enemy_zealots:
                    closest_enemy_zealot = enemy_zealots.closest_to(zealot)
                    if closest_enemy_zealot:
                        if zealot.distance_to(closest_enemy_zealot) > 1:
                            zealot.attack(closest_enemy_zealot)
                        else:
                            zealot.attack(closest_enemy_zealot)
```

### Explanation:
1. **Colossus**:
   - The Colossus will prioritize attacking the enemy Colossus if it exists.
   - If the enemy Colossus is not present, it will attack the closest enemy unit.

2. **Stalkers**:
   - The Stalkers will kite the enemy units by attacking and then retreating slightly to maintain distance.
   - They will only attack if the enemy is within their range (6 units).

3. **Zealots**:
   - The Zealots will charge towards the enemy Zealots and engage in melee combat.
   - They will attack the closest enemy Zealot if within range (1 unit).

This strategy ensures that each unit type is utilized effectively based on their strengths and weaknesses. The code avoids using the `await` keyword and checks whether the list variables are empty before performing actions.
